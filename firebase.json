{
    "hosting": {
    "public": "dist",
    "ignore": [
      "firebase.json",
      "**/.*",
      "**/node_modules/**"
    ],
    "rewrites": [
        {
        "source": "**",
        "destination": "/index.html"
        }
    ],
    "frameworksBackend": {
        "region": "asia-east1",
        "minInstances": 1, //注意事項有り
        "maxInstances": 2
    }
  }
}
